# Environment Variables

# Database
DATABASE_URL="postgresql://user:password@localhost:5432/renovation"

# NextAuth
NEXTAUTH_SECRET="your-super-secret-key-change-in-production"
NEXTAUTH_URL="http://localhost:3000"

# OpenClaw Gateway
OPENCLAW_URL="ws://localhost:18789"
OPENCLAW_TOKEN="your-openclaw-gateway-token"

# A2A Server (optional)
A2A_SERVER_URL="http://localhost:8080"
A2A_API_KEY="your-a2a-api-key"

# Agent Endpoints (optional)
AGENT_DEMAND_ANALYZER_URL="http://localhost:3001"
AGENT_LAYOUT_DESIGNER_URL="http://localhost:3002"
AGENT_RENDERING_URL="http://localhost:3003"
AGENT_MATERIAL_URL="http://localhost:3004"
AGENT_SUPERVISOR_URL="http://localhost:3005"

# Storage (optional)
UPLOAD_DIR="./uploads"
