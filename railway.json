{
  "$schema": "https://railway.app/schema.json",
  "build": {
    "builder": "NIXPACKS_V1",
    "buildCommand": "npm install && npx prisma generate && next build",
    "startCommand": "next start"
  },
  "deploy": {
    "numReplicas": 1,
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10
  }
}
